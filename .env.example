# =============================================================================
# Yardstick — environment configuration
# =============================================================================
#
# Copy to `.env.local` at the repo root (preferred) or `.env`.
# Loaded by apps/server on startup; keys propagate to spawned Python agent jobs.
#
#   cp .env.example .env.local
#
# Minimum to run dashboards (no chat, no agent jobs):
#   (none — scorecard/compare/workbench work from g4a-benchmarks artifacts)
#
# Minimum for dev chat:
#   ANTHROPIC_API_KEY=...
#
# Minimum for measurement agent jobs (via UI or agent_runner.py):
#   ANTHROPIC_API_KEY=...
#   Team clones under YARDSTICK_CLONE_ROOT (see Paths)
#
# =============================================================================


# -----------------------------------------------------------------------------
# LLM — chat, future TS agent
# -----------------------------------------------------------------------------
# Provider: anthropic | openai (openai is stub-only until implemented)
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic (chat FAB, future in-process agent)
ANTHROPIC_API_KEY=

# Chat / Yardstick assistant model (apps/server → packages/llm)
# Examples: claude-sonnet-4-20250514, claude-opus-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Reserved for OpenAI provider (not implemented yet)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o


# -----------------------------------------------------------------------------
# Measurement agent — Python bridge (g4a-harness/agent_runner.py)
# -----------------------------------------------------------------------------
# Separate from chat model — agent uses tool loop + sandbox; defaults to Opus.
# When jobs are queued from Yardstick server, process.env is inherited.
AGENT_MODEL=claude-opus-4-8

# Harness can also load g4a-harness/.env directly when run standalone.
# If you only maintain one file, root .env.local is enough for `pnpm dev`.


# -----------------------------------------------------------------------------
# Observability / tracing
# -----------------------------------------------------------------------------
# langfuse — send traces when keys present (default)
# noop     — disable tracing entirely
TRACE_PROVIDER=langfuse

# Langfuse (https://langfuse.com) — chat turns, sync, agent jobs
# Leave blank for local noop tracing (no errors; /api/health shows tracer mode)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# LangSmith / other backends: not wired yet. TRACE_PROVIDER only supports
# langfuse | noop today. See packages/observability/ to add adapters.


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_PATH=.yardstick/db.sqlite


# -----------------------------------------------------------------------------
# Paths — repo layout and clones
# -----------------------------------------------------------------------------
# Root of g4a-bench monorepo (auto-detected if unset)
YARDSTICK_REPO_ROOT=.

# Where team repos are cloned for verification + dev chat code search.
# Layout: {YARDSTICK_CLONE_ROOT}/{cohort}/week-{n}/{runId}/{team-slug}/
YARDSTICK_CLONE_ROOT=.yardstick/clones

# Legacy prototype clone path (dev chat also checks):
#   /private/tmp/g4a-bench-prototype/{cohort}/week-{n}/{runId}/{team}


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=5183

# Web dev server (apps/web) on 5184; proxies /api → PORT above.
# Ship/challenger stacks often use 5173 (web) + 3000 (api) — Yardstick uses 5184 + 5183.


# -----------------------------------------------------------------------------
# Dev chat — include clone source in context
# -----------------------------------------------------------------------------
# When true: chat context adds coverage_gaps, ripgrep hits, tsconfig snippets
# from team clones. Use to investigate blank scorecard cells (e.g. untyped params).
YARDSTICK_DEV_MODE=true

# Alias for YARDSTICK_DEV_MODE
# CHAT_INCLUDE_CODE=true


# -----------------------------------------------------------------------------
# TypeScript verification (harness AST counter)
# -----------------------------------------------------------------------------
# Path to typescript package used by ts_violation_counter.cjs / verify_typesafety.
# Default if unset: /tmp/tsverify/node_modules/typescript
#
# One-time setup example:
#   mkdir -p /tmp/tsverify && cd /tmp/tsverify && npm init -y && npm i typescript
TS_LIB=/tmp/tsverify/node_modules/typescript


# -----------------------------------------------------------------------------
# CI / tooling (optional)
# -----------------------------------------------------------------------------
# CI=true                    # Playwright: forbidOnly, no reuseExistingServer
