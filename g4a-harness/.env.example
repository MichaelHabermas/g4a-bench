# =============================================================================
# g4a-harness — Python measurement agent (standalone)
# =============================================================================
#
# Copy to g4a-harness/.env (gitignored). Used when running agent_runner.py
# directly. When Yardstick queues jobs via `pnpm dev`, the server inherits
# root `.env.local` — you may not need this file if keys live at repo root.
#
#   cp .env.example .env
#
# See also: ../.env.example for full Yardstick configuration (Langfuse, DB,
# dev chat, clone paths, chat model vs agent model).
# =============================================================================


# Required for real agent runs (omit for --dry-run wiring checks)
ANTHROPIC_API_KEY=

# Agent model — tool-use measurement loop (higher effort than chat)
# Override default claude-opus-4-8 if needed
AGENT_MODEL=claude-sonnet-4-20250514

# TypeScript compiler for AST verification (ts_violation_counter.js)
# TS_LIB=/tmp/tsverify/node_modules/typescript
